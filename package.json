{
  "name": "@owl/core",
  "version": "0.1.0",
  "description": "OWL (OWASP Web Shield Library): practical OWASP Top 10 mitigation helpers for JavaScript apps",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/adapters/react"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "esbuild src/index.js --bundle --platform=node --format=esm --outfile=dist/index.js",
    "build:cjs": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "lint": "eslint .",
    "check": "npm run lint && npm run test"
  },
  "keywords": [
    "owasp",
    "security",
    "javascript",
    "react",
    "webshield"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "globals": "^15.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@testing-library/react": "^16.1.0"
  }
}