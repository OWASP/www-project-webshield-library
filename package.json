{
  "name": "@owsl/core",
  "version": "1.0.0",
  "description": "OWL (OWASP Web Shield Library): practical OWASP Top 10 mitigation helpers for JavaScript apps",
  "private": false,
  "type": "module",
  "workspaces": [
    "src/adapters/react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWASP/www-project-webshield-library.git"
  },
  "homepage": "https://owasp.org/www-project-webshield-library/",
  "bugs": {
    "url": "https://github.com/OWASP/www-project-webshield-library/issues"
  },
  "author": "OWASP Web Shield Library Project",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "esbuild src/index.js --bundle --platform=node --format=esm --outfile=dist/index.js",
    "build:cjs": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "lint": "eslint .",
    "check": "npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "owasp",
    "owasp-top10",
    "security",
    "javascript",
    "typescript",
    "react",
    "webshield",
    "rbac",
    "acl",
    "csrf",
    "ssrf",
    "authentication",
    "authorization",
    "crypto",
    "input-sanitization",
    "secure-coding"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "funding": {
    "type": "individual",
    "url": "https://owasp.org/donate/"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "globals": "^15.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@testing-library/react": "^16.1.0"
  }
}