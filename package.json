{
  "name": "@owasp/webshield",
  "version": "0.1.0",
  "description": "Framework-agnostic OWASP security library for JavaScript applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js"
    },
    "./react": {
      "types": "./dist/adapters/react/index.d.ts",
      "require": "./dist/adapters/react/index.js",
      "import": "./dist/adapters/react/index.esm.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "require": "./dist/core/index.js",
      "import": "./dist/core/index.esm.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -m esnext -d false --outDir dist --declarationMap false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "keywords": [
    "security",
    "owasp",
    "authentication",
    "access-control",
    "rbac",
    "acl",
    "csrf",
    "input-validation",
    "sanitization"
  ],
  "author": "OWASP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OWASP/webshield.git"
  }
}
